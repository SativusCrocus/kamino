# ─── REQUIRED ─────────────────────────────────────────
# Your Phantom wallet PUBLIC key only (for monitoring)
WALLET_ADDRESS=your_phantom_public_key_here

# Helius free RPC (get at helius.dev — free tier is enough)
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ─── OPTIONAL: Telegram alerts ────────────────────────
# Create a bot via @BotFather on Telegram, get the token
# Then start a chat with your bot and get your chat ID via:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── AUTONOMOUS EXECUTION ─────────────────────────────
# Your wallet PRIVATE KEY (base58 encoded) — required for auto-execution
# Export from Phantom: Settings → Security → Export Private Key
# ⚠️  NEVER share this. NEVER commit this file.
WALLET_PRIVATE_KEY=

# Set to true to enable autonomous deposits/withdrawals
# When false, the bot only monitors and alerts (safe mode)
AUTO_EXECUTE=false
